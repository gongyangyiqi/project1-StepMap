# Development environment
APP_ENV=development
APP_NAME=StepMap API
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

# SQLite for quick local development (switch to PostgreSQL in production)
DATABASE_URL=sqlite:///./stepmap_dev.db

JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# MinIO / S3 placeholders
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=stepmap-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
