# Development environment template
APP_ENV=development
APP_NAME=StepMap API
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://stepmap:stepmap@localhost:5432/stepmap
JWT_SECRET_KEY=replace-with-dev-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=stepmap-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
